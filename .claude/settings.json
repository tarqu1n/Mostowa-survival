{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "extraKnownMarketplaces": {
    "hermes-skills": {
      "source": {
        "source": "github",
        "repo": "third-bridge/hermes-ai-tooling"
      }
    }
  },
  "enabledPlugins": {
    "hermes-dev@hermes-skills": true
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/guard-full-e2e.sh\"",
            "timeout": 10,
            "statusMessage": "Checking e2e scope guard"
          }
        ]
      }
    ]
  }
}
